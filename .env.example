# Server
PORT=3000

# API Authentication — generate a strong random key for securing your API.
# Send as `X-Api-Key: <key>` or `Authorization: Bearer <key>`. Query-string
# auth is not supported (keys leak into logs and history).
API_KEY=your-secret-api-key-here

# ─── CORS ─────────────────────────────────────────────────────────
# Comma-separated allowlist of origins that may call the API from a browser.
# Leave unset to deny all cross-origin browser requests (the PWA bundled with
# the server is same-origin, so it always works). Server-to-server callers
# (Claude API, ChatGPT Actions, Bee scripts) ignore CORS.
# Example: CORS_ORIGINS=https://chat.openai.com,https://claude.ai
CORS_ORIGINS=

# ─── Notion Backend ───────────────────────────────────────────────
# 1. Create a Notion integration at https://www.notion.so/my-integrations
# 2. Copy the "Internal Integration Secret" here
NOTION_TOKEN=ntn_your-notion-integration-token

# 3. Run POST /api/setup with { "parent_page_id": "your-page-id" }
#    to auto-create all databases. Then paste the returned IDs here:
NOTION_DB_KNOWLEDGE=
NOTION_DB_FACTS=
NOTION_DB_TASKS=
NOTION_DB_PROJECTS=
NOTION_DB_TRANSCRIPTS=
NOTION_DB_ACTIVITY_LOG=

# ─── Smart Intake (AI auto-classification) ────────────────────────
# Required for POST /api/intake — uses GPT-4o-mini to classify input
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# ─── Auto-Sync (Cron) ────────────────────────────────────────────
# Interval in minutes between automatic syncs (default: 30)
SYNC_INTERVAL=30

# ─── Bee.computer (optional) ─────────────────────────────────────
# Run "bee login" on your Mac, then: cat ~/.bee/token-prod
# BEE_API_TOKEN=your-bee-token

# ─── Email Index (Gmail via MCP) ─────────────────────────────────
# The brain stores POINTERS to email threads (subject, summary, embedding) but
# never the bodies. Bodies are fetched on demand from the source.
#
# MCP server URL (the gmail-multi MCP server you've already deployed)
MCP_GMAIL_URL=https://gmail-multi-mcp-production.up.railway.app/mcp
# Optional bearer token if your MCP server requires auth
MCP_GMAIL_TOKEN=
# Classifier + embedding models (defaults are fine; uses your OPENAI_API_KEY)
EMAIL_CLASSIFIER_MODEL=gpt-4o-mini
EMAIL_EMBEDDING_MODEL=text-embedding-3-small
# Calendar uses the same MCP server (gcal_* tools); models default to email's
CALENDAR_CLASSIFIER_MODEL=gpt-4o-mini
CALENDAR_EMBEDDING_MODEL=text-embedding-3-small
# Comma-separated list of YOUR addresses. Used as a recipient filter so we
# don't accidentally index mail addressed to other people in shared mailboxes.
USER_EMAIL_ADDRESSES=avibar.ny@gmail.com,avibar.js@gmail.com,avi.lilach@gmail.com,avi.solar@gmail.com,abar@thinkalpen.com

# ─── Cron: Auto-ingest schedules ─────────────────────────────────
# Email cron defaults: ON if OPENAI_API_KEY + MCP_GMAIL_URL are set.
# Set EMAIL_SYNC_ENABLED=false to force off, or =true to force on.
# EMAIL_SYNC_ENABLED=
# How often to pull (minutes). Default 30.
EMAIL_SYNC_INTERVAL=30
# Comma-separated MCP account aliases. Default 'js'. Add more like 'js,ny,solar'.
EMAIL_SYNC_ACCOUNTS=js
# Look-back window per cron run. Default 2 (incremental — relies on idempotent upsert).
EMAIL_SYNC_DAYS=2
# Max threads per account per run.
EMAIL_SYNC_LIMIT=100

# Calendar cron — same shape, longer interval (events change less often).
# CALENDAR_SYNC_ENABLED=
CALENDAR_SYNC_INTERVAL=60
CALENDAR_SYNC_ACCOUNTS=js
# Future days to pull (default 14).
CALENDAR_SYNC_DAYS=14
# Past days to pull (default 1 — keep tiny, just to catch edits to recent events).
CALENDAR_SYNC_PAST=1
CALENDAR_SYNC_LIMIT=200
