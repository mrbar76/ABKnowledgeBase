# Server
PORT=3000

# API Authentication — generate a strong random key for securing your API
API_KEY=your-secret-api-key-here

# ─── Notion Backend ───────────────────────────────────────────────
# 1. Create a Notion integration at https://www.notion.so/my-integrations
# 2. Copy the "Internal Integration Secret" here
NOTION_TOKEN=ntn_your-notion-integration-token

# 3. Run POST /api/setup with { "parent_page_id": "your-page-id" }
#    to auto-create all 7 databases. Then paste the returned IDs here:
NOTION_DB_KNOWLEDGE=
NOTION_DB_TASKS=
NOTION_DB_PROJECTS=
NOTION_DB_TRANSCRIPTS=
NOTION_DB_HEALTH_METRICS=
NOTION_DB_WORKOUTS=
NOTION_DB_ACTIVITY_LOG=

# ─── Auto-Sync (Cron) ────────────────────────────────────────────
# Interval in minutes between automatic syncs (default: 30)
SYNC_INTERVAL=30

# ─── Bee.computer (optional) ─────────────────────────────────────
# Run "bee login" on your Mac, then: cat ~/.bee/token-prod
# BEE_API_TOKEN=your-bee-token
