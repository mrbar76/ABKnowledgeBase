{
  "openapi": "3.1.0",
  "info": {
    "title": "AB Brain - Knowledge Base API",
    "description": "Personal knowledge base, task management, and transcript storage for AI-augmented workflows.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://ab-brain.up.railway.app/api"
    }
  ],
  "paths": {
    "/knowledge": {
      "get": {
        "operationId": "searchKnowledge",
        "summary": "Search or list knowledge entries",
        "parameters": [
          { "name": "q", "in": "query", "schema": { "type": "string" }, "description": "Full-text search query" },
          { "name": "category", "in": "query", "schema": { "type": "string" }, "description": "Filter by category" },
          { "name": "tag", "in": "query", "schema": { "type": "string" }, "description": "Filter by tag" },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 50 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } }
        ],
        "responses": {
          "200": {
            "description": "Knowledge entries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "count": { "type": "integer" },
                    "entries": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/KnowledgeEntry" }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createKnowledge",
        "summary": "Save a new knowledge entry",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title", "content"],
                "properties": {
                  "title": { "type": "string", "description": "Short descriptive title" },
                  "content": { "type": "string", "description": "Full knowledge content" },
                  "category": { "type": "string", "enum": ["general", "code", "meeting", "research", "decision", "reference", "personal"], "default": "general" },
                  "tags": { "type": "array", "items": { "type": "string" } },
                  "ai_source": { "type": "string", "default": "chatgpt" },
                  "metadata": { "type": "object" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string", "format": "uuid" },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/knowledge/{id}": {
      "get": {
        "operationId": "getKnowledgeEntry",
        "summary": "Get a single knowledge entry by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Knowledge entry",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/KnowledgeEntry" }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateKnowledge",
        "summary": "Update a knowledge entry",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": { "type": "string" },
                  "content": { "type": "string" },
                  "category": { "type": "string" },
                  "tags": { "type": "array", "items": { "type": "string" } },
                  "metadata": { "type": "object" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated" }
        }
      },
      "delete": {
        "operationId": "deleteKnowledge",
        "summary": "Delete a knowledge entry",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Deleted" }
        }
      }
    },
    "/tasks": {
      "get": {
        "operationId": "listTasks",
        "summary": "List tasks with optional filters",
        "parameters": [
          { "name": "project_id", "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["todo", "in_progress", "review", "done"] } },
          { "name": "ai_agent", "in": "query", "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 100 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } }
        ],
        "responses": {
          "200": {
            "description": "Tasks list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "count": { "type": "integer" },
                    "tasks": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Task" }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createTask",
        "summary": "Create a new task",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title"],
                "properties": {
                  "title": { "type": "string" },
                  "description": { "type": "string" },
                  "project_id": { "type": "string", "format": "uuid" },
                  "status": { "type": "string", "enum": ["todo", "in_progress", "review", "done"], "default": "todo" },
                  "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"], "default": "medium" },
                  "ai_agent": { "type": "string", "default": "chatgpt" },
                  "next_steps": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Task created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string", "format": "uuid" },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/tasks/{id}": {
      "get": {
        "operationId": "getTask",
        "summary": "Get a single task",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Task details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Task" }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateTask",
        "summary": "Update a task (status, next_steps, etc.)",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": { "type": "string" },
                  "description": { "type": "string" },
                  "status": { "type": "string", "enum": ["todo", "in_progress", "review", "done"] },
                  "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
                  "next_steps": { "type": "string" },
                  "output_log": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated" }
        }
      },
      "delete": {
        "operationId": "deleteTask",
        "summary": "Delete a task",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Deleted" }
        }
      }
    },
    "/projects": {
      "get": {
        "operationId": "listProjects",
        "summary": "List projects",
        "parameters": [
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["active", "paused", "completed", "archived"] } }
        ],
        "responses": {
          "200": {
            "description": "Projects list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "count": { "type": "integer" },
                    "projects": { "type": "array", "items": { "$ref": "#/components/schemas/Project" } }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createProject",
        "summary": "Create a new project",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" },
                  "description": { "type": "string" },
                  "status": { "type": "string", "default": "active" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Project created" }
        }
      }
    },
    "/transcripts": {
      "get": {
        "operationId": "searchTranscripts",
        "summary": "Search or list transcripts",
        "parameters": [
          { "name": "q", "in": "query", "schema": { "type": "string" } },
          { "name": "source", "in": "query", "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 50 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } }
        ],
        "responses": {
          "200": {
            "description": "Transcripts list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "count": { "type": "integer" },
                    "transcripts": { "type": "array", "items": { "$ref": "#/components/schemas/Transcript" } }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "uploadTranscript",
        "summary": "Upload a new transcript",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["raw_text"],
                "properties": {
                  "title": { "type": "string" },
                  "raw_text": { "type": "string" },
                  "summary": { "type": "string" },
                  "source": { "type": "string", "default": "bee" },
                  "speaker_labels": { "type": "array", "items": { "type": "object" } },
                  "duration_seconds": { "type": "integer" },
                  "recorded_at": { "type": "string", "format": "date-time" },
                  "tags": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Transcript uploaded" }
        }
      }
    },
    "/search": {
      "get": {
        "operationId": "unifiedSearch",
        "summary": "Search across ALL data types (knowledge, transcripts, tasks, projects) in one query",
        "description": "Unified search that queries knowledge entries, transcripts, tasks, and projects simultaneously. Returns results grouped by type with relevance ranking. Use this as the primary search method.",
        "parameters": [
          { "name": "q", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Search query" },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": {
          "200": {
            "description": "Grouped search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "query": { "type": "string" },
                    "total": { "type": "integer" },
                    "results": {
                      "type": "object",
                      "properties": {
                        "knowledge": { "type": "array", "items": { "type": "object" } },
                        "transcripts": { "type": "array", "items": { "type": "object" } },
                        "tasks": { "type": "array", "items": { "type": "object" } },
                        "projects": { "type": "array", "items": { "type": "object" } }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/search/ai": {
      "post": {
        "operationId": "aiSearch",
        "summary": "AI-powered search across the entire knowledge base",
        "description": "Submit a natural language query to search across all data types. Returns results sorted by relevance with a summary. Designed for AI agents to search and retrieve the user's personal data.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["query"],
                "properties": {
                  "query": { "type": "string", "description": "Natural language search query" },
                  "limit": { "type": "integer", "default": 10 }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results with summary",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "query": { "type": "string" },
                    "total": { "type": "integer" },
                    "summary": { "type": "string" },
                    "results": { "type": "array", "items": { "type": "object" } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/workouts": {
      "get": {
        "operationId": "listWorkouts",
        "summary": "List or search workout logs",
        "parameters": [
          { "name": "q", "in": "query", "schema": { "type": "string" }, "description": "Full-text search query" },
          { "name": "workout_type", "in": "query", "schema": { "type": "string", "enum": ["hill", "strength", "run", "hybrid", "recovery", "ruck"] } },
          { "name": "tag", "in": "query", "schema": { "type": "string" }, "description": "Filter by tag (e.g. spartan, carry)" },
          { "name": "since", "in": "query", "schema": { "type": "string", "format": "date" }, "description": "Workouts on or after this date" },
          { "name": "before", "in": "query", "schema": { "type": "string", "format": "date" }, "description": "Workouts before this date" },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 50 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } }
        ],
        "responses": {
          "200": {
            "description": "Workout log entries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "total": { "type": "integer" },
                    "count": { "type": "integer" },
                    "workouts": { "type": "array", "items": { "$ref": "#/components/schemas/Workout" } }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "logWorkout",
        "summary": "Log a new Spartan workout with structured fields for type, workout details, metrics, performance, body feedback, and adjustments",
        "description": "Post a structured workout log. ChatGPT should use this after a workout recap conversation. Include workout_type, focus, warmup, main_sets, carries, metrics (time, distance, elevation), effort rating 1-10, performance notes (slowdown, failure point), body feedback (grip, legs, cardio, shoulder), and adjustment for next time. Tags should be lowercase without # prefix.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["workout_type"],
                "properties": {
                  "title": { "type": "string", "description": "Auto-generated if empty: 'Spartan Workout – DATE – TYPE'" },
                  "workout_date": { "type": "string", "format": "date", "description": "YYYY-MM-DD, defaults to today" },
                  "workout_type": { "type": "string", "enum": ["hill", "strength", "run", "hybrid", "recovery", "ruck"] },
                  "location": { "type": "string", "description": "e.g. Runyon Canyon, Home Gym" },
                  "elevation": { "type": "string", "description": "Base elevation if relevant, e.g. 1,320 ft" },
                  "focus": { "type": "string", "description": "Goal of the workout, e.g. hill durability, grip endurance" },
                  "warmup": { "type": "string", "description": "Warm-up activities" },
                  "main_sets": { "type": "string", "description": "Main workout sets and exercises" },
                  "carries": { "type": "string", "description": "Carries, lifts, or loaded movements" },
                  "time_duration": { "type": "string", "description": "Total time, e.g. 45 min, 1:15:00" },
                  "distance": { "type": "string", "description": "Distance covered, e.g. 3.2 mi" },
                  "elevation_gain": { "type": "string", "description": "Elevation gained, e.g. 850 ft" },
                  "effort": { "type": "integer", "minimum": 1, "maximum": 10, "description": "Effort rating 1-10" },
                  "slowdown_notes": { "type": "string", "description": "Where did I slow down or break form" },
                  "failure_first": { "type": "string", "description": "What failed first: legs / grip / cardio / shoulders" },
                  "grip_feedback": { "type": "string", "description": "Grip status: solid / pumped / gave out" },
                  "legs_feedback": { "type": "string", "description": "Legs status: strong / heavy / cramped" },
                  "cardio_feedback": { "type": "string", "description": "Cardio status: steady / gasping / recovered fast" },
                  "shoulder_feedback": { "type": "string", "description": "Shoulder status: fine / tight / clicking" },
                  "body_notes": { "type": "string", "description": "Additional body feedback or recovery notes" },
                  "adjustment": { "type": "string", "description": "What to change next time: weight, pace, structure" },
                  "tags": { "type": "array", "items": { "type": "string" }, "description": "Tags without # prefix, e.g. [\"spartan\", \"hill\", \"carry\"]" },
                  "ai_source": { "type": "string", "default": "chatgpt" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Workout logged",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Workout" }
              }
            }
          }
        }
      }
    },
    "/workouts/bulk": {
      "post": {
        "operationId": "bulkImportWorkouts",
        "summary": "Bulk import up to 200 workouts at once",
        "description": "Import historical workouts from Apple Health, Fitbod, or any batch data. Each item uses the same fields as logWorkout. Only workout_type is required per entry.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["workouts"],
                "properties": {
                  "workouts": {
                    "type": "array",
                    "maxItems": 200,
                    "items": {
                      "type": "object",
                      "required": ["workout_type"],
                      "properties": {
                        "workout_type": { "type": "string" },
                        "workout_date": { "type": "string", "format": "date" },
                        "title": { "type": "string" },
                        "location": { "type": "string" },
                        "focus": { "type": "string" },
                        "warmup": { "type": "string" },
                        "main_sets": { "type": "string" },
                        "carries": { "type": "string" },
                        "exercises": { "type": "array", "items": { "type": "object" } },
                        "class_name": { "type": "string" },
                        "program": { "type": "string" },
                        "equipment": { "type": "string" },
                        "instructor": { "type": "string" },
                        "time_duration": { "type": "string" },
                        "distance": { "type": "string" },
                        "elevation_gain": { "type": "string" },
                        "heart_rate_avg": { "type": "string" },
                        "heart_rate_max": { "type": "string" },
                        "pace_avg": { "type": "string" },
                        "splits": { "type": "string" },
                        "cadence_avg": { "type": "string" },
                        "active_calories": { "type": "string" },
                        "total_calories": { "type": "string" },
                        "effort": { "type": "integer", "minimum": 1, "maximum": 10 },
                        "slowdown_notes": { "type": "string" },
                        "failure_first": { "type": "string" },
                        "grip_feedback": { "type": "string" },
                        "legs_feedback": { "type": "string" },
                        "cardio_feedback": { "type": "string" },
                        "shoulder_feedback": { "type": "string" },
                        "body_notes": { "type": "string" },
                        "adjustment": { "type": "string" },
                        "tags": { "type": "array", "items": { "type": "string" } },
                        "ai_source": { "type": "string", "default": "chatgpt" },
                        "metadata": { "type": "object" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Bulk import results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "imported": { "type": "integer" },
                    "errors": { "type": "integer" },
                    "results": { "type": "array", "items": { "type": "object" } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/dashboard": {
      "get": {
        "operationId": "getDashboard",
        "summary": "Get dashboard stats (knowledge count, tasks by status, recent activity)",
        "responses": {
          "200": {
            "description": "Dashboard overview",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "knowledge": { "type": "object" },
                    "projects": { "type": "object" },
                    "tasks": { "type": "object" },
                    "transcripts": { "type": "object" },

                    "recent_activity": { "type": "array" }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "KnowledgeEntry": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "title": { "type": "string" },
          "content": { "type": "string" },
          "category": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "source": { "type": "string" },
          "ai_source": { "type": "string" },
          "metadata": { "type": "object" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "Task": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "project_id": { "type": "string", "format": "uuid" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "status": { "type": "string" },
          "priority": { "type": "string" },
          "ai_agent": { "type": "string" },
          "next_steps": { "type": "string" },
          "output_log": { "type": "string" },
          "project_name": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "Project": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "status": { "type": "string" },
          "task_counts": { "type": "object" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "Workout": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "title": { "type": "string" },
          "workout_date": { "type": "string", "format": "date" },
